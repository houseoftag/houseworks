generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ColumnType {
  TEXT
  STATUS
  PERSON
  DATE
  LINK
  NUMBER
  TIMELINE
  CLIENT
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
}

enum NotificationType {
  ASSIGNMENT
  COMMENT
  STATUS_CHANGE
  MENTION
  DUE_DATE
}

enum ActivityType {
  COMMENT
  STATUS_CHANGE
  ASSIGNMENT
  FIELD_EDIT
  ITEM_CREATED
  ITEM_DELETED
  ITEM_MOVED
  BOARD_CREATED
  BOARD_UPDATED
  BOARD_DELETED
  BOARD_DUPLICATED
  MEMBER_ADDED
  MEMBER_REMOVED
  AUTOMATION_TRIGGERED
  ATTACHMENT_ADDED
  ATTACHMENT_DELETED
}

enum BoardType {
  STANDARD
  CRM
}

enum CrmEntryType {
  NOTE
  DOCUMENT
  DELIVERABLE
  EMAIL
  INVOICE
  MEETING
  CALL
}

enum EmailProvider {
  GMAIL
  OUTLOOK
}

enum DependencyType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
  DUPLICATES
}

enum EntityType {
  WORKSPACE
  BOARD
  ITEM
  COLUMN
  GROUP
  ATTACHMENT
}

model User {
  id                   String            @id @default(cuid())
  name                 String?
  email                String?           @unique
  emailVerified        DateTime?         @map("email_verified")
  image                String?
  role                 UserRole          @default(MEMBER)
  passwordHash         String?           @map("password_hash")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  accounts             Account[]
  sessions             Session[]
  workspacesOwned      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  boardsCreated        Board[]           @relation("BoardCreator")
  invitesCreated       WorkspaceInvite[] @relation("InviteCreator")
  updates              Update[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  templatesCreated     BoardTemplate[] @relation("TemplateCreator")
  attachments          Attachment[]    @relation("AttachmentUploader")
  dependenciesCreated  ItemDependency[] @relation("DependencyCreator")
  boardPrefs           UserBoardPrefs[]
  notificationPrefs    NotificationPreference[]
  crmTimelineEntries   CrmTimelineEntry[]        @relation("TimelineEntryCreator")

  @@map("users")
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  ownerId   String            @map("owner_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members   WorkspaceMember[]
  boards    Board[]
  invites   WorkspaceInvite[]
  automations           Automation[]
  templates             BoardTemplate[]
  activityLogs          ActivityLog[]
  emailIntegrations     EmailIntegration[]
  quickBooksIntegration QuickBooksIntegration?
  clients               Client[]
  unmatchedEmails       UnmatchedEmail[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String         @id @default(cuid())
  workspaceId String         @map("workspace_id")
  userId      String         @map("user_id")
  role        WorkspaceRole  @default(MEMBER)
  createdAt   DateTime       @default(now()) @map("created_at")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String         @id @default(cuid())
  workspaceId String         @map("workspace_id")
  email       String
  role        WorkspaceRole  @default(MEMBER)
  token       String         @unique
  expiresAt   DateTime       @map("expires_at")
  acceptedAt  DateTime?      @map("accepted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  createdById String?        @map("created_by_id")
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?          @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invites")
}

model Board {
  id           String    @id @default(cuid())
  workspaceId  String    @map("workspace_id")
  title        String
  description  String?
  boardType    BoardType @default(STANDARD) @map("board_type")
  ownerId      String?   @map("owner_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?     @relation("BoardCreator", fields: [ownerId], references: [id])
  groups       Group[]
  columns      Column[]
  automations  Automation[]
  activityLogs ActivityLog[]
  views        BoardView[]
  userPrefs    UserBoardPrefs[]
  notificationPrefs NotificationPreference[]

  @@index([workspaceId])
  @@map("boards")
}

model Automation {
  id          String              @id @default(cuid())
  workspaceId String              @map("workspace_id")
  boardId     String?             @map("board_id")
  name        String
  enabled     Boolean             @default(true)
  trigger     Json
  conditions  Json?
  actions     Json
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board       Board?              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  logs        AutomationLog[]

  @@index([workspaceId])
  @@index([boardId])
  @@map("automations")
}

model AutomationLog {
  id           String              @id @default(cuid())
  automationId String              @map("automation_id")
  status       AutomationLogStatus
  payload      Json
  message      String?
  createdAt    DateTime            @default(now()) @map("created_at")
  automation   Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("automation_logs")
}

model Group {
  id        String   @id @default(cuid())
  boardId   String   @map("board_id")
  title     String
  color     String?
  position  Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items     Item[]

  @@index([boardId])
  @@map("groups")
}

model Item {
  id         String      @id @default(cuid())
  groupId    String      @map("group_id")
  name       String
  description String?   @db.Text
  position   Float
  externalId String?     @map("external_id")
  recurrence Json?
  nextDueDate DateTime?  @map("next_due_date")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  clientId   String?     @map("client_id")
  group      Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  client     Client?     @relation(fields: [clientId], references: [id])
  cellValues    CellValue[]
  updates       Update[]
  activityLogs  ActivityLog[]
  attachments   Attachment[]
  dependenciesAsSource ItemDependency[] @relation("DependencySource")
  dependenciesAsTarget ItemDependency[] @relation("DependencyTarget")
  @@index([groupId])
  @@index([clientId])
  @@index([nextDueDate])
  @@map("items")
}

model Update {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("updates")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  itemId    String?          @map("item_id")
  boardId   String?          @map("board_id")
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@map("notifications")
}

model ActivityLog {
  id          String       @id @default(cuid())
  workspaceId String       @map("workspace_id")
  boardId     String?      @map("board_id")
  itemId      String?      @map("item_id")
  userId      String       @map("user_id")
  type        ActivityType
  entityType  EntityType?  @map("entity_type")
  entityId    String?      @map("entity_id")
  field       String?
  oldValue    Json?        @map("old_value")
  newValue    Json?        @map("new_value")
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board       Board?       @relation(fields: [boardId], references: [id], onDelete: SetNull)
  item        Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([boardId])
  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model BoardTemplate {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  thumbnail   String?
  columnConfig Json    @map("column_config")  // Array of { title, type, settings, position }
  groupConfig  Json    @map("group_config")   // Array of { title, color, position }
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("TemplateCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@map("board_templates")
}

model Column {
  id        String      @id @default(cuid())
  boardId   String      @map("board_id")
  title     String
  type      ColumnType
  settings  Json        @default("{}")
  position  Float
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  board     Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cells     CellValue[]

  @@index([boardId])
  @@map("columns")
}

model CellValue {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  columnId  String   @map("column_id")
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  column    Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([itemId, columnId])
  @@index([columnId])
  @@map("cell_values")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Attachment {
  id           String   @id @default(cuid())
  itemId       String   @map("item_id")
  fileName     String   @map("file_name")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  url          String
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("attachments")
}

model ItemDependency {
  id           String         @id @default(cuid())
  sourceItemId String         @map("source_item_id")
  targetItemId String         @map("target_item_id")
  type         DependencyType
  createdById  String         @map("created_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  sourceItem   Item           @relation("DependencySource", fields: [sourceItemId], references: [id], onDelete: Cascade)
  targetItem   Item           @relation("DependencyTarget", fields: [targetItemId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("DependencyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([sourceItemId, targetItemId, type])
  @@index([sourceItemId])
  @@index([targetItemId])
  @@map("item_dependencies")
}

model BoardView {
  id        String   @id @default(cuid())
  boardId   String   @map("board_id")
  name      String
  filters   Json     @default("{}")
  sort      Json     @default("{}")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@map("board_views")
}

model UserBoardPrefs {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  boardId      String   @map("board_id")
  columnWidths Json     @default("{}")
  subscribed   Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  board        Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
  @@index([userId])
  @@index([boardId])
  @@map("user_board_prefs")
}

model NotificationPreference {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  type      NotificationType?
  boardId   String?           @map("board_id")
  enabled   Boolean           @default(true)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  board     Board?            @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, type, boardId])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── CRM Models ────────────────────────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  displayName  String   @map("display_name")
  company      String?
  email        String?
  website      String?
  phone        String?
  address      String?
  tier         String?
  domains      String[] @default([])
  tags         String[] @default([])
  customFields Json     @default("{}") @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  timeline     CrmTimelineEntry[]
  items        Item[]
  contacts     Contact[]
  unmatchedEmails UnmatchedEmail[]

  @@index([workspaceId])
  @@map("clients")
}

model CrmTimelineEntry {
  id          String       @id @default(cuid())
  clientId    String       @map("client_id")
  type        CrmEntryType
  title       String
  body        String?      @db.Text
  entryDate   String?      @map("entry_date")
  entryTime   String?      @map("entry_time")
  metadata    Json         @default("{}")
  createdById String?      @map("created_by_id")
  externalId  String?      @map("external_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("TimelineEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdAt])
  @@map("crm_timeline_entries")
}

model EmailIntegration {
  id           String        @id @default(cuid())
  workspaceId  String        @map("workspace_id")
  provider     EmailProvider
  accessToken  String        @map("access_token") @db.Text
  refreshToken String?       @map("refresh_token") @db.Text
  email        String
  syncedAt     DateTime?     @map("synced_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@map("email_integrations")
}

// ─── Contacts ──────────────────────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  displayName String   @map("display_name")
  email       String?
  phone       String?
  role        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contacts")
}

// ─── Unmatched Emails ─────────────────────────────────────────────────────────

model UnmatchedEmail {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  threadId      String   @unique @map("thread_id")
  messageId     String?  @map("message_id")
  fromEmail     String   @map("from_email")
  fromName      String?  @map("from_name")
  fromDomain    String   @map("from_domain")
  subject       String
  bodyPreview   String?  @map("body_preview") @db.Text
  receivedAt    DateTime @map("received_at")
  status        String   @default("pending")  // pending | assigned | dismissed
  assignedToId  String?  @map("assigned_to_id")
  createdAt     DateTime @default(now()) @map("created_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo    Client?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([fromDomain])
  @@map("unmatched_emails")
}

// ─── QuickBooks Integration ────────────────────────────────────────────────────

model QuickBooksIntegration {
  id           String    @id @default(cuid())
  workspaceId  String    @unique @map("workspace_id")
  realmId      String    @map("realm_id")
  accessToken  String    @map("access_token") @db.Text
  refreshToken String    @map("refresh_token") @db.Text
  syncedAt     DateTime? @map("synced_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("quickbooks_integrations")
}
